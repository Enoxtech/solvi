{
  "expo": {
    "name": "SOLVI",
    "slug": "solvi-app",
    "scheme": "solvi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#070E1C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.solvi.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#070E1C"
      },
      "package": "app.solvi.mobile"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dbf2c935-4766-4863-ba4a-4f967d6bbaac"
      }
    },
    "owner": "enoxxs-organization"
  }
}
